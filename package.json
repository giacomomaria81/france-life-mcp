{
  "name": "france-life-mcp",
  "version": "1.0.0",
  "description": "MCP server for daily life in France — 20 tools covering weather, health, transport, schools, admin, housing, and more. Powered by free French government APIs.",
  "main": "dist/index.js",
  "bin": {
    "france-life-mcp": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch"
  },
  "keywords": [
    "mcp", "france", "french-api", "model-context-protocol", "claude",
    "ai-tools", "government-api", "daily-life", "expat", "open-data"
  ],
  "author": "Giacomo Pilia <giacomomaria@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.24"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": ["dist", "README.md", "LICENSE"]
}
